.pyre/
.pytype/

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Logs and runtime temp files
*.log
*.pid
*.out

# Environment and local secrets
.env
.env.*
!.env.example

# Node / frontend artifacts
node_modules/
coverage/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo

# OS files
